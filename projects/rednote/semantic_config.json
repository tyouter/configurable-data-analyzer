  "metrics": {
    "dau": {
      "business_name": "日活用户",
      "sql": "COUNT(DISTINCT reduser_id)",
      "keywords": [
        "日活",
        "DAU",
        "日活跃",
        "每天活跃"
      ],
      "description": "按天去重统计用户数"
    },
    "total_users": {
      "business_name": "总用户数",
      "sql": "COUNT(DISTINCT reduser_id) OVER()",
      "keywords": [
        "总用户",
        "全部用户"
      ],
      "description": "数据集中的全部去重用户数（固定值），用作活跃率的分母"
    },
    "activity_rate": {
      "business_name": "用户活跃率",
      "sql": "CAST(COUNT(DISTINCT reduser_id) AS DOUBLE) / NULLIF(COUNT(DISTINCT reduser_id) OVER(), 0)",
      "keywords": [
        "活跃率",
        "活跃比例",
        "DAU比例",
        "用户活跃率"
      ],
      "description": "活跃率 = 当天DAU / 总用户数（百分比）。分子是当天去重用户数，分母是全量数据的去重用户总数。SQL示例: SELECT event_date, COUNT(DISTINCT reduser_id) as dau, COUNT(DISTINCT reduser_id) OVER() as total_users, ROUND(CAST(COUNT(DISTINCT reduser_id) AS DOUBLE) / NULLIF((SELECT COUNT(DISTINCT reduser_id) FROM events), 0) * 100, 2) as activity_rate_pct FROM events GROUP BY event_date ORDER BY event_date"
    },
    "total_events": {
      "business_name": "总事件数",
      "sql": "COUNT(*)",
      "keywords": [
        "事件数",
        "总事件",
        "操作数"
      ]
    },
    "avg_events_per_user": {
      "business_name": "人均事件数",
      "sql": "CAST(COUNT(*) AS DOUBLE) / COUNT(DISTINCT reduser_id)",
      "keywords": [
        "人均事件",
        "平均事件"
      ]
    },
    "avg_duration": {
      "business_name": "平均停留时长",
      "sql": "AVG(duration_sec)",
      "keywords": [
        "平均时长",
        "停留时间",
        "停留时长"
      ]
    },
