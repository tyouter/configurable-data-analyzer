      ],
      "note": "该字段只在笔记卡片相关事件中填充，其他事件为NULL。用于分析卡片点击的位置分布。"
    },
    "rednote_post_is_like": {
      "business_name": "笔记是否点赞",
      "type": "string",
      "role": "dimension",
      "description": "小红书笔记是否喜欢"
    },
    "rednote_post_is_save": {
      "business_name": "笔记是否收藏",
      "type": "string",
      "role": "dimension",
      "description": "saved=已收藏变未收藏, not_saved=未收藏变已收藏"
    },
    "rednote_post_follow": {
      "business_name": "是否关注",
      "type": "string",
      "role": "dimension",
      "description": "true=从未关注变为已关注, false=从已关注变为未关注"
    },
    "rednote_user_logging_status": {
      "business_name": "用户登录状态",
