  "columns": {
    "reduser_id": {
      "business_name": "用户ID",
      "type": "string",
      "role": "dimension",
      "description": "唯一用户标识"
    },
    "device_id": {
      "business_name": "设备ID",
      "type": "string",
      "role": "dimension",
      "description": "唯一设备标识"
    },
    "event_name": {
      "business_name": "事件名称",
      "type": "string",
      "role": "dimension",
      "description": "埋点事件全名，格式如 discovery_page_post_card_click"
    },
    "start_time": {
      "business_name": "事件开始时间",
      "type": "timestamp",
      "role": "dimension"
    },
    "end_time": {
      "business_name": "事件结束时间",
      "type": "timestamp",
      "role": "dimension"
    },
    "event_date": {
      "business_name": "日期",
      "type": "date",
      "role": "dimension",
      "derived": true,
      "derived_from": "start_time",
      "derivation_logic": "CAST(start_time AS DATE)",
      "description": "事件发生日期（从 start_time 派生）"
    },
    "event_hour": {
      "business_name": "小时",
      "type": "integer",
      "role": "dimension",
      "derived": true,
      "derived_from": "start_time",
      "derivation_logic": "EXTRACT(HOUR FROM start_time)",
      "description": "事件发生小时(0-23)（从 start_time 派生）"
    },
    "event_weekday": {
      "business_name": "星期几",
      "type": "integer",
      "role": "dimension",
      "derived": true,
      "derived_from": "start_time",
      "derivation_logic": "EXTRACT(DOW FROM start_time) - 1",
      "description": "0=周一, 6=周日（从 start_time 派生）"
    },
    "is_weekend": {
      "business_name": "是否周末",
      "type": "integer",
      "role": "dimension",
      "derived": true,
      "derived_from": "event_weekday",
      "derivation_logic": "CASE WHEN event_weekday IN (5,6) THEN 1 ELSE 0 END",
      "description": "1=周末, 0=工作日（从 event_weekday 派生）"
    },
    "page_root": {
      "business_name": "页面模块",
      "type": "string",
      "role": "dimension",
      "derived": true,
      "derived_from": "event_name",
      "derivation_logic": "SPLIT_PART(event_name, '_', 1)",
      "description": "事件名称第一段（从 event_name 派生）",
      "enum": [
        "discovery",
        "porsche",
        "poi_detail",
        "post_detail",
        "profile",
        "search_homepage",
        "search_results",
        "trival_guide",
        "login",
        "navigation_bar",
        "other_profile",
        "Profile"
      ]
    },
    "page": {
      "business_name": "页面",
      "type": "string",
      "role": "dimension",
      "derived": true,
      "derived_from": "event_name",
      "derivation_logic": "SPLIT_PART(event_name, '_', 1) || '_' || SPLIT_PART(event_name, '_', 2)",
      "description": "事件名称前两段（从 event_name 派生）"
    },
    "action": {
      "business_name": "动作",
      "type": "string",
      "role": "dimension",
      "derived": true,
      "derived_from": "event_name",
      "derivation_logic": "最后一个下划线后的部分",
      "description": "事件名称最后一段（从 event_name 派生）"
    },
    "is_click": {
      "business_name": "是否点击",
      "type": "integer",
      "role": "dimension",
      "derived": true,
      "derived_from": "action",
      "derivation_logic": "CASE WHEN action LIKE '%click%' THEN 1 ELSE 0 END",
      "description": "1=点击事件（从 action 派生）"
    },
    "duration_sec": {
      "business_name": "停留时长(秒)",
      "type": "float",
      "role": "measure",
      "derived": true,
      "derived_from": "start_time, end_time",
      "derivation_logic": "EXTRACT(EPOCH FROM end_time - start_time)",
      "description": "事件持续时间（从 end_time - start_time 派生）"
    },
    "rednote_poi_title": {
      "business_name": "POI名称",
      "type": "string",
      "role": "dimension",
      "description": "相关POI地点名称"
    },
    "rednote_poi_type": {
      "business_name": "POI类型",
      "type": "string",
      "role": "dimension",
      "description": "POI类型代码"
    },
    "rednote_poi_type_name": {
      "business_name": "POI分类名称",
      "type": "string",
      "role": "dimension",
      "description": "POI分类的中文名称"
    },
    "rednote_poi_map_fullscreen": {
      "business_name": "地图是否全屏",
      "type": "string",
      "role": "dimension",
      "description": "小红书同城地图是否全屏（0=未全屏, 1=全屏）"
