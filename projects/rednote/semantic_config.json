    "rednote_post_title": {
      "business_name": "笔记标题",
      "type": "string",
      "role": "dimension",
      "description": "相关笔记标题"
    },
    "rednote_post_type": {
      "business_name": "笔记类型",
      "type": "string",
      "role": "dimension",
      "description": "笔记类型"
    },
    "rednote_post_num": {
      "business_name": "笔记位置序号",
      "type": "float",
      "role": "dimension",
      "description": "笔记卡片的位置序号（从1开始），仅在卡片曝光/点击事件中有值",
      "available_events": [
        "discovery_page_post_card_cardshow",
        "discovery_page_post_card_click",
        "porsche_page_recommend_post_card_cardshow",
        "porsche_page_recommend_post_card_click",
