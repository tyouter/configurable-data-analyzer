    {
      "chart_id": "chart_12",
      "name": "APP 有效登录率趋势",
      "category": "trend",
      "chart_type": "line",
      "description": "查看每天/每周/每月，APP 登录用户占比的趋势",
      "x_axis": {"field": "event_date", "label": "时间"},
      "y_axis": [
        {"metric_ref": "app_valid_login_rate", "series_type": "line", "label": "有效登录率"}
      ],
      "dimensions": ["event_date"],
      "filters": []
