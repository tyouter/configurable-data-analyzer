    {
      "chart_id": "chart_13",
      "name": "活跃用户（高，中，低）分布",
      "category": "profile",
      "chart_type": "boxplot",
      "description": "查看某段时间段内用户产生的总事件次数统计其分布，按中位数，上下4分位",
      "custom_sql": "SELECT reduser_id, COUNT(*) as event_cnt FROM events GROUP BY reduser_id ORDER BY event_cnt",
      "x_axis": {"label": "用户活跃度"},
      "y_axis": {"label": "事件次数", "statistics": ["min", "p25", "median", "p75", "max"]},
      "filters": []
    },
    {
      "chart_id": "chart_14",
      "name": "核心功能渗透率",
      "category": "function",
      "chart_type": "kpi_card",
      "kpi_format": "percent_1dp",
      "description": "查看某段时间段内核心功能使用用户占总体用户的比例（AI路书all，Porsche+页面点赞收藏，地图操作all，发起导航）",
      "metric_ref": "core_function_penetration",
      "dimensions": [],
      "filters": []
    },
    {
      "chart_id": "chart_15",
      "name": "APP 活跃用户留存率 3/7/14天",
      "category": "function",
      "chart_type": "kpi_card",
      "kpi_format": "percent_1dp",
      "description": "查看活跃用户在3，7，14天三个时间窗口下的留存率",
      "analysis_type": "retention",
      "analysis_params": {
        "anchor_event": "login_page_pageshow",
        "return_event": "login_page_pageshow",
        "day_offsets": [3, 7, 14]
      },
      "dimensions": [],
      "filters": []
    },
    {
      "chart_id": "chart_16",
      "name": "核心功能用户留存率 3/7/14天",
      "category": "function",
      "chart_type": "kpi_card",
      "kpi_format": "percent_1dp",
      "description": "查看核心功能使用用户在3，7，14天三个时间窗口下的留存率",
      "analysis_type": "retention",
      "analysis_params": {
        "anchor_event": "post_detail_page_ai_travel_guide_button_click",
        "return_event": "login_page_pageshow",
        "day_offsets": [3, 7, 14]
      },
      "dimensions": [],
      "filters": []
