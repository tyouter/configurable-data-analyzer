    {
      "chart_id": "chart_21",
      "name": "Porsche+页帖子顺位分布（按人数）",
      "category": "porsche",
      "chart_type": "bar",
      "description": "查看Porsche+页面不同的位置帖子被浏览的量的分布，即热帖的位置分布",
      "custom_sql": "SELECT CAST(rednote_post_num AS INT) as position, COUNT(DISTINCT reduser_id) as user_count FROM events WHERE span_name ILIKE '%porsche_page%post_card%' AND rednote_post_num IS NOT NULL GROUP BY position ORDER BY position",
      "x_axis": {"field": "position", "label": "帖子位置序号"},
      "y_axis": {"field": "user_count", "label": "人数"},
      "filters": []
    },
    {
      "chart_id": "chart_22",
      "name": "运营位帖子点击率",
      "category": "porsche",
      "chart_type": "kpi_card",
      "kpi_format": "percent_1dp",
      "description": "某段时间内运营位帖子的点击率（点击量/曝光量）",
      "metric_ref": "operational_post_ctr",
      "dimensions": [],
      "filters": []
