    },
    {
      "chart_id": "chart_24",
      "name": "导航来源",
      "category": "conversion",
      "chart_type": "pie",
      "description": "路书详情->导航 & POI详情->导航 这两条导航路径的来源分布，按次数统计",
      "custom_sql": "SELECT CASE WHEN span_name = 'trival_guide_page_detail_tab_poi_navigation_button_click' THEN '路书详情->导航' WHEN span_name = 'poi_detail_page_navigation_button_click' THEN 'POI详情->导航' ELSE '其他' END as source, COUNT(*) as cnt FROM events WHERE span_name IN ('trival_guide_page_detail_tab_poi_navigation_button_click', 'poi_detail_page_navigation_button_click') GROUP BY source ORDER BY cnt DESC",
      "x_axis": {},
      "y_axis": {},
      "filters": []
    },
    {
      "chart_id": "chart_25",
      "name": "POI 详情来源",
      "category": "conversion",
      "chart_type": "pie",
      "description": "Porsche+地图->POI详情 & 帖子->POI详情，这两条POI详情页访问路径的来源分布，按次数统计",
      "custom_sql": "SELECT CASE WHEN referer_page = 'map_view' THEN 'Porsche+地图->POI详情' WHEN referer_page = 'note_detail_page' THEN '帖子->POI详情' WHEN referer_page = 'poi_search_results_p' THEN 'POI搜索->POI详情' ELSE COALESCE(referer_page, '其他') END as source, COUNT(*) as cnt FROM events WHERE span_name = 'poi_detail_page_pageshow' AND referer_page IS NOT NULL AND referer_page != '' GROUP BY source ORDER BY cnt DESC",
      "x_axis": {},
      "y_axis": {},
      "filters": []
    },
    {
      "chart_id": "chart_26",
      "name": "AI 路书来源",
      "category": "conversion",
      "chart_type": "pie",
      "description": "点击生成AI路书 & 从分享码下载",
      "custom_sql": "SELECT CASE WHEN span_name = 'post_detail_page_ai_travel_guide_button_click' THEN '点击生成AI路书' WHEN span_name = 'profile_page_travel_guide_tab_share_code_trip_add_confirm_button_click' THEN '从分享码下载' ELSE '其他' END as source, COUNT(*) as cnt FROM events WHERE span_name IN ('post_detail_page_ai_travel_guide_button_click', 'profile_page_travel_guide_tab_share_code_trip_add_confirm_button_click') GROUP BY source ORDER BY cnt DESC",
      "x_axis": {},
      "y_axis": {},
      "filters": []
    },
    {
      "chart_id": "chart_27",
      "name": "点击AI路书生成转化率",
      "category": "conversion",
      "chart_type": "kpi_card",
      "kpi_format": "percent_1dp",
      "description": "某段时间内，AI路书生成点击次数/AI路书生成曝光次数",
      "metric_ref": "ai_guide_conversion_rate",
      "dimensions": [],
      "filters": []
