      "x_axis": {"field": "event_date", "label": "时间"},
      "y_axis": [
        {"metric_ref": "app_valid_login_users", "series_type": "bar", "label": "有效登录人数"},
        {"metric_ref": "app_valid_login_rate", "series_type": "line", "label": "有效登录率"}
      ],
      "legend": {"selectable": true, "items": ["有效登录人数", "有效登录率"]},
      "dimensions": ["event_date"],
      "filters": []
