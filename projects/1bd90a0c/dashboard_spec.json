{
  "version": "1.0",
  "name": "小红书KPI看板",
  "description": "基于 Rednote dashboard V1.0 5-30 requirements.xlsx 定义的33个图表规范",
  "global_filters": [
    {"field": "event_date", "type": "date_range", "label": "时间范围"},
    {"field": "platform", "type": "select", "label": "Platform", "options": ["Asterix", "HCP3"]},
    {"field": "app_version", "type": "multi_select", "label": "app_version"},
    {"field": "os_version", "type": "multi_select", "label": "os_version"},
    {"field": "screen_size", "type": "multi_select", "label": "screen_size"},
    {"field": "display_id", "type": "select", "label": "标识主副屏", "options": ["0.0"]},
    {"field": "user_ip", "type": "multi_select", "label": "IP归属地"}
  ],
  "categories": [
    {"id": "total_summary", "label": "Total summary", "order": 1},
    {"id": "trend", "label": "Trend", "order": 2},
    {"id": "profile", "label": "Profile", "order": 3},
    {"id": "function", "label": "Function", "order": 4},
    {"id": "porsche", "label": "Porsche+ 种草", "order": 5},
    {"id": "conversion", "label": "拔草", "order": 6},
    {"id": "ranking", "label": "Ranking", "order": 7}
  ],
  "charts": [
    {
      "chart_id": "chart_01",
      "name": "APP 装机量",
      "category": "total_summary",
      "chart_type": "kpi_card",
      "kpi_format": "integer",
      "description": "查看某段时间APP装机的总数",
      "metric_ref": "app_installs",
      "dimensions": [],
      "filters": []
    },
    {
      "chart_id": "chart_02",
      "name": "APP 活跃人数",
      "category": "total_summary",
      "chart_type": "kpi_card",
      "kpi_format": "integer",
      "description": "查看某段时间APP活跃的总用户数量",
      "metric_ref": "app_active_users",
      "dimensions": [],
      "filters": []
    },
    {
      "chart_id": "chart_03",
      "name": "APP 新增用户人数",
      "category": "total_summary",
      "chart_type": "kpi_card",
      "kpi_format": "integer",
      "description": "查看某段时间内 APP 的新增用户的总数量",
      "metric_ref": "app_new_users",
      "dimensions": [],
      "filters": []
    },
    {
      "chart_id": "chart_04",
      "name": "APP 人均使用时长",
      "category": "total_summary",
      "chart_type": "kpi_card",
      "kpi_format": "integer_minutes",
      "description": "APP用户的平均使用时长，按天/周/月三个维度查看",
      "metric_ref": "app_avg_usage_duration",
      "dimensions": [],
      "filters": [{"field": "event_date", "granularity": "day/week/month"}]
    },
    {
      "chart_id": "chart_05",
      "name": "APP 装机量趋势",
      "category": "trend",
      "chart_type": "bar_line",
      "description": "查看每天/每周/每月，装机量的趋势",
      "x_axis": {"field": "event_date", "label": "时间"},
      "y_axis": [
        {"metric_ref": "app_installs", "series_type": "bar", "label": "装机量"},
        {"metric_ref": "app_install_growth_rate", "series_type": "line", "label": "装机增长率"}
      ],
      "legend": {"selectable": true, "items": ["装机量", "装机增长率"]},
      "dimensions": ["event_date"],
      "filters": []
    },
    {
      "chart_id": "chart_06",
      "name": "APP 装机增长率趋势",
      "category": "trend",
      "chart_type": "line",
      "description": "查看每天/每周/每月，装机增长率的趋势",
      "x_axis": {"field": "event_date", "label": "时间"},
      "y_axis": [
        {"metric_ref": "app_install_growth_rate", "series_type": "line", "label": "装机增长率"}
      ],
      "dimensions": ["event_date"],
      "filters": []
    },
    {
      "chart_id": "chart_07",
      "name": "APP 活跃人数趋势",
      "category": "trend",
      "chart_type": "bar_line",
      "description": "查看每天/每周/每月，APP活跃的用户数量趋势",
      "x_axis": {"field": "event_date", "label": "时间"},
      "y_axis": [
        {"metric_ref": "app_active_users", "series_type": "bar", "label": "活跃人数"},
        {"metric_ref": "app_active_rate", "series_type": "line", "label": "活跃率"}
      ],
      "legend": {"selectable": true, "items": ["活跃人数", "活跃率"]},
      "dimensions": ["event_date"],
      "filters": []
    },
    {
      "chart_id": "chart_08",
      "name": "APP 活跃率趋势",
      "category": "trend",
      "chart_type": "line",
      "description": "查看每天/每周/每月，APP活跃的用户活跃率趋势",
      "x_axis": {"field": "event_date", "label": "时间"},
      "y_axis": [
        {"metric_ref": "app_active_rate", "series_type": "line", "label": "活跃率"}
      ],
      "dimensions": ["event_date"],
      "filters": []
    },
    {
      "chart_id": "chart_09",
      "name": "APP 新增用户人数趋势",
      "category": "trend",
      "chart_type": "bar_line",
      "description": "查看每天/每周/每月，APP新增用户人数的趋势",
      "x_axis": {"field": "event_date", "label": "时间"},
      "y_axis": [
        {"metric_ref": "app_new_users", "series_type": "bar", "label": "新增用户人数"},
        {"metric_ref": "app_user_growth_rate", "series_type": "line", "label": "用户增长率"}
      ],
      "legend": {"selectable": true, "items": ["新增用户人数", "用户增长率"]},
      "dimensions": ["event_date"],
      "filters": []
    },
    {
      "chart_id": "chart_10",
      "name": "APP 用户增长率趋势",
      "category": "trend",
      "chart_type": "line",
      "description": "查看每天/每周/每月，APP用户增长率的趋势",
      "x_axis": {"field": "event_date", "label": "时间"},
      "y_axis": [
        {"metric_ref": "app_user_growth_rate", "series_type": "line", "label": "用户增长率"}
      ],
      "dimensions": ["event_date"],
      "filters": []
    },
    {
      "chart_id": "chart_11",
      "name": "APP 有效登录人数趋势",
