    {
      "chart_id": "chart_28",
      "name": "AI路书分享码生成率",
      "category": "conversion",
      "chart_type": "kpi_card",
      "kpi_format": "percent_1dp",
      "description": "某段时间内，分享码生成点击次数/(AI分享码下载点击次数+生成AI路书点击次数)",
      "metric_ref": "share_code_generation_rate_v2",
      "dimensions": [],
      "filters": []
    },
    {
      "chart_id": "chart_29",
