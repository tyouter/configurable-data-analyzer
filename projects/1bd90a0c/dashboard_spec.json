    },
    {
      "chart_id": "chart_30",
      "name": "AI路书分享码生成用户数量",
      "category": "conversion",
      "chart_type": "kpi_card",
      "kpi_format": "integer",
      "description": "某段时间内，AI路书分享码生成按钮被点击的用户数量总数",
      "metric_ref": "share_code_gen_users_v2",
      "dimensions": [],
