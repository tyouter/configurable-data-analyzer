    },
    {
      "chart_id": "chart_31",
      "name": "AI路书分享码下载用户数量",
      "category": "conversion",
      "chart_type": "kpi_card",
      "kpi_format": "integer",
      "description": "某段时间内，AI路书下载确认按钮被点击的用户数量总数",
      "metric_ref": "share_code_download_users",
      "dimensions": [],
      "filters": []
    },
    {
      "chart_id": "chart_32",
      "name": "热门POI TOP10 Ranking",
      "category": "ranking",
      "chart_type": "ranking_bar",
      "description": "某段时间内所有被访问的POI按照类型统计其被访问次数的排名前10",
      "custom_sql": "SELECT rednote_poi_title, COUNT(*) as visit_count FROM events WHERE span_name ILIKE '%poi%' AND rednote_poi_title IS NOT NULL AND rednote_poi_title != '' GROUP BY rednote_poi_title ORDER BY visit_count DESC LIMIT 10",
      "x_axis": {"field": "rank", "label": "Rank"},
      "y_axis": {"field": "visit_count", "label": "被访问次数"},
      "filters": []
    },
    {
      "chart_id": "chart_33",
      "name": "热门城市 TOP10 Ranking",
      "category": "ranking",
      "chart_type": "ranking_bar",
      "description": "某段时间内所有按照IP城市统计的事件次数的排名前10",
      "custom_sql": "SELECT user_ip as city, COUNT(*) as event_count FROM events WHERE user_ip IS NOT NULL AND user_ip != '' GROUP BY user_ip ORDER BY event_count DESC LIMIT 10",
      "x_axis": {"field": "rank", "label": "Rank"},
      "y_axis": {"field": "event_count", "label": "事件总数"},
      "filters": []
    }
  ]
}
