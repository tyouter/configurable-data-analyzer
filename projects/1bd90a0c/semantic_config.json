  "alias_rules": [
    {
      "condition": {
        "all_of": [
          {
            "contains": "discovery"
          },
          {
            "contains": "post_card"
          },
          {
            "contains": "click"
          }
        ]
      },
      "aliases": [
        "发现页帖子卡片点击",
        "发现页-笔记卡片点击"
      ]
    },
    {
      "condition": {
        "all_of": [
          {
            "contains": "discovery"
          },
          {
            "contains": "post_card"
          },
          {
            "contains": "cardshow"
          }
        ]
      },
      "aliases": [
        "发现页帖子卡片展示"
      ]
    },
    {
      "condition": {
        "all_of": [
          {
            "contains": "porsche"
          },
          {
            "contains": "map_poi"
          },
          {
            "contains": "click"
          }
        ]
      },
      "aliases": [
        "Porsche+地图POI卡片点击"
      ]
    },
    {
      "condition": {
        "all_of": [
          {
            "contains": "post_detail"
          },
          {
            "contains": "ai_travel_guide"
          },
          {
            "contains": "click"
          }
        ]
      },
      "aliases": [
        "帖子详情页AI路书按钮点击",
        "AI路书生成入口点击"
      ]
    },
    {
      "condition": {
        "all_of": [
          {
            "contains": "trival_guide"
          },
          {
            "contains": "add_place"
          },
          {
            "contains": "click"
          }
        ]
      },
      "aliases": [
        "路书页添加地点点击"
      ]
    }
  ],
