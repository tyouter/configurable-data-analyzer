  "metrics": {
    "total_events": {
      "business_name": "总事件数",
      "metric_type": "count",
      "sql": "COUNT(*)",
      "keywords": "事件总量",
      "description": "统计周期内所有事件的总数量",
      "chart_hint": "kpi_card",
      "business_domain": "overview",
      "business_domain_label": "APP总览"
    },
    "app_installs": {
      "business_name": "APP装机量",
      "metric_type": "count",
      "sql": "COUNT(DISTINCT reduser_id) FILTER (WHERE span_name IN ('login_page_pageshow', 'discovery_page_pageshow'))",
      "keywords": "装机量,安装",
      "description": "统计周期内打开过APP的用户数（KPI1.2/1.3口径：login_page_pageshow或discovery_page_pageshow）",
      "chart_hint": "kpi_card",
      "business_domain": "overview",
      "business_domain_label": "APP总览"
    },
    "app_active_users": {
      "business_name": "APP活跃人数",
      "metric_type": "count",
      "sql": "COUNT(DISTINCT reduser_id)",
      "keywords": "DAU, 活跃用户, 活跃人数",
      "description": "统计周期内至少一次有效APP操作的活跃用户数（KPI1.6口径：排除无效数据——仅1条discovery_page_pageshow且曝光时长<5s的用户）",
      "chart_hint": "kpi_card",
      "business_domain": "overview",
      "business_domain_label": "APP总览"
    },
    "app_new_users": {
      "business_name": "APP新增用户人数",
      "metric_type": "count",
      "sql": "COUNT(DISTINCT reduser_id) FILTER (WHERE event_date = (SELECT MIN(e2.event_date) FROM events e2 WHERE e2.reduser_id = events.reduser_id))",
      "keywords": "新增用户, 新用户",
      "description": "统计周期内首次出现的用户数",
      "chart_hint": "kpi_card",
      "business_domain": "overview",
      "business_domain_label": "APP总览"
    },
    "app_avg_usage_duration": {
      "business_name": "APP人均使用时长",
      "metric_type": "duration",
      "sql": "AVG(EXTRACT(EPOCH FROM (end_time_nano::TIMESTAMP - start_time_nano::TIMESTAMP))) / 60.0",
      "keywords": "使用时长, 人均时长",
      "description": "APP用户的平均使用时长（分钟），基于KPI1.5曝光时长计算口径",
      "chart_hint": "kpi_card",
      "business_domain": "overview",
      "business_domain_label": "APP总览"
    },
    "app_install_growth_rate": {
      "business_name": "APP装机增长率",
      "metric_type": "rate",
      "sql": "0",
      "keywords": "装机增长率",
      "description": "装机量环比增长率，需按时间维度计算（当日装机量-前日装机量）/前日装机量",
      "chart_hint": "line",
      "business_domain": "overview",
      "business_domain_label": "APP总览",
      "requires_lag": true
    },
    "app_active_rate": {
      "business_name": "APP活跃率",
      "metric_type": "rate",
      "sql": "COUNT(DISTINCT reduser_id) * 1.0 / (SELECT COUNT(DISTINCT reduser_id) FROM events)",
      "keywords": "活跃率, APP",
      "description": "KPI1.6口径：排除无效数据（仅1条discovery_page_pageshow且曝光时长<5s）后的活跃用户数/总用户数",
      "chart_hint": "line",
      "business_domain": "overview",
      "business_domain_label": "APP总览"
    },
    "app_user_growth_rate": {
      "business_name": "APP用户增长率",
