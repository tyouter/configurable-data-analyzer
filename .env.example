# ChatBI MCP Server - Environment Configuration
# Copy this file to .env and fill in your values

# Required: LLM API Key
DEEPSEEK_API_KEY=your_api_key_here

# Optional: LLM API Base URL (default: https://api.deepseek.com)
# For OpenAI-compatible APIs, change to your provider's endpoint
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: LLM Model (default: deepseek-chat)
# BI_MODEL=deepseek-chat

# Optional: Projects data directory (default: ./projects)
# CHATBI_PROJECTS_DIR=./projects
